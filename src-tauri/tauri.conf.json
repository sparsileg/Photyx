{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "photyx",
    "version": "0.1.0",
    "identifier": "com.stanb.photyx",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../build"
    },
    "app": {
        "windows": [
            {
                "title": "Photyx",
                "width": 950,
                "height": 1125,
                "x": 1000,
                "y": 100,
                "resizable": true,
                "fullscreen": false,
                "devtools": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "plugins": {
        "dialog": null
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
